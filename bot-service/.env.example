# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Supabase (EchoBrief project: qjhysesjocanowmdkeme) ───────────────────────
SUPABASE_URL=https://qjhysesjocanowmdkeme.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Transcription ─────────────────────────────────────────────────────────────
# Primary: Sarvam Saaras v3 streaming STT
SARVAM_API_KEY=your-sarvam-api-key-here

# Fallback: OpenAI Whisper batch API
OPENAI_API_KEY=your-openai-api-key-here

# ── Bot Config ────────────────────────────────────────────────────────────────
BOT_CONCURRENCY=5
AUDIO_OUTPUT_DIR=/tmp/echobrief-audio

# Path to Chromium binary (set automatically in Docker)
# CHROMIUM_PATH=/usr/bin/chromium

# Set to 'true' to start server without the BullMQ worker (for testing)
# SKIP_WORKER=false
